---
import type { Locale } from '@/lib/i18n';
import { getContent } from '@/lib/content';
import Eyebrow from './Eyebrow.astro';
interface Props { locale: Locale }
const { locale } = Astro.props;
const t = getContent(locale);
---
<section class="border-t border-sand bg-bone">
  <div class="mx-auto max-w-[1240px] px-6 py-20 lg:px-10 lg:py-24">
    <div class="reveal mb-12 max-w-[40rem]">
      <Eyebrow text={t.recognition.eyebrow} class="mb-5" />
      <h2 class="font-serif text-[clamp(1.8rem,3.4vw,2.6rem)] font-bold leading-[1.12] text-ink">{t.recognition.heading}</h2>
    </div>
    <div class="grid grid-cols-1 gap-8 md:grid-cols-3">
      {t.recognition.cards.map((c, i) => (
        <article class="reveal border-t-2 border-green/30 pt-6" style={`transition-delay:${i * 0.07}s`}>
          <h3 class="mb-2.5 font-serif text-[21px] font-bold leading-snug text-ink">{c.org}</h3>
          <p class="text-[15.5px] leading-relaxed text-clay">{c.detail}</p>
        </article>
      ))}
    </div>
  </div>
</section>
