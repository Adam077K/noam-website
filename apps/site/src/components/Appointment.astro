---
import type { Locale } from '@/lib/i18n';
import { getContent } from '@/lib/content';
import Eyebrow from './Eyebrow.astro';
interface Props { locale: Locale }
const { locale } = Astro.props;
const t = getContent(locale);
const a = t.appointment;
const field = 'w-full rounded-xl border border-white/25 bg-white/[0.07] px-4 py-3 text-[15.5px] text-white placeholder-cloud/80 transition-colors focus:border-blue-bright focus:bg-white/[0.12] focus:outline-none focus:ring-2 focus:ring-blue/30';
---
<section id="contact" class="scroll-mt-20 bg-ink">
  <div class="mx-auto grid max-w-[1240px] grid-cols-1 gap-12 px-6 py-20 lg:grid-cols-[1.1fr_0.9fr] lg:gap-16 lg:px-10 lg:py-28">
    <!-- form -->
    <div class="reveal">
      <Eyebrow text={a.eyebrow} tone="light" class="mb-5" />
      <h2 class="mb-3 font-serif text-[clamp(1.9rem,3.6vw,2.85rem)] font-bold leading-[1.12] text-white">{a.heading}</h2>
      <p class="mb-8 max-w-[34rem] text-[17px] leading-relaxed text-cloud">{a.sub}</p>

      <form id="appt-form" class="space-y-4" novalidate>
        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
          <label class="block">
            <span class="mb-1.5 block text-[13.5px] font-medium text-cloud">{a.fields.name}</span>
            <input name="name" type="text" required autocomplete="name" class={field} />
          </label>
          <label class="block">
            <span class="mb-1.5 block text-[13.5px] font-medium text-cloud">{a.fields.phone}</span>
            <input name="phone" type="tel" required autocomplete="tel" dir="ltr" class={field} />
          </label>
        </div>
        <label class="block">
          <span class="mb-1.5 block text-[13.5px] font-medium text-cloud">{a.fields.email}</span>
          <input name="email" type="email" required autocomplete="email" dir="ltr" class={field} />
        </label>
        <label class="block">
          <span class="mb-1.5 block text-[13.5px] font-medium text-cloud">{a.fields.message}</span>
          <textarea name="message" rows="4" class={`${field} resize-none`}></textarea>
        </label>
        <!-- honeypot -->
        <input type="text" name="company" tabindex="-1" autocomplete="off" class="absolute -left-[9999px] h-0 w-0" aria-hidden="true" />

        <div class="flex flex-wrap items-center gap-4 pt-1">
          <button type="submit" class="rounded-xl bg-blue px-8 py-3.5 text-[16px] font-semibold text-white transition-colors hover:bg-blue-bright disabled:opacity-60">
            <span data-label>{a.submit}</span>
          </button>
          <span class="text-[14px] text-cloud">
            {a.phoneLabel} <a href={a.phoneHref} dir="ltr" class="font-semibold text-white underline decoration-white/30 underline-offset-4 hover:decoration-blue-bright">{a.phone}</a>
          </span>
        </div>
        <p data-status role="status" aria-live="polite" class="hidden rounded-xl px-4 py-3 text-[14.5px]"></p>
        <p class="text-[12.5px] leading-relaxed text-cloud/80">{a.consent}</p>
      </form>
    </div>

    <!-- clinic card -->
    <aside id="clinic" class="reveal scroll-mt-24 self-start rounded-[22px] border border-white/10 bg-white/4 p-7 lg:p-8" style="transition-delay:.08s">
      <h3 class="mb-6 font-serif text-[22px] font-bold text-white">{t.footer.clinic}</h3>
      <dl class="space-y-5 text-[15.5px]">
        <div class="flex gap-3.5">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" class="mt-0.5 shrink-0 text-blue-bright" aria-hidden="true"><path d="M12 21s-7-5.2-7-10a7 7 0 0 1 14 0c0 4.8-7 10-7 10Z"/><circle cx="12" cy="11" r="2.5"/></svg>
          <dd class="leading-relaxed text-[#cdd9e6]">{t.footer.address}</dd>
        </div>
        <div class="flex gap-3.5">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" class="mt-0.5 shrink-0 text-blue-bright" aria-hidden="true"><path d="M4 5c0 8.3 6.7 15 15 15l2.5-2.5-4-3-2 1.5a11 11 0 0 1-5.5-5.5L13 8.5l-3-4Z"/></svg>
          <dd><a href={a.phoneHref} dir="ltr" class="text-[#cdd9e6] hover:text-white" style="display:inline-block">{a.phone}</a></dd>
        </div>
        <div class="flex gap-3.5">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" class="mt-0.5 shrink-0 text-blue-bright" aria-hidden="true"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3.5 7 8.5 6 8.5-6"/></svg>
          <dd><a href={t.utility.emailHref} class="text-[#cdd9e6] hover:text-white">{t.utility.email}</a></dd>
        </div>
      </dl>
      <a
        href="https://www.google.com/maps/search/?api=1&query=Menachem+Begin+156+Tel+Aviv"
        target="_blank" rel="noopener noreferrer"
        class="group relative mt-7 block overflow-hidden rounded-xl border border-white/12"
        style="aspect-ratio:16/10;background:linear-gradient(135deg,#16314a,#0e2236);"
        aria-label={locale === 'he' ? 'צפייה במפה ב-Google Maps' : 'View on Google Maps'}
      >
        <span class="pointer-events-none absolute inset-0 opacity-[0.5]" aria-hidden="true"
          style="background:repeating-linear-gradient(0deg,transparent 0 26px,rgba(255,255,255,0.05) 26px 27px),repeating-linear-gradient(90deg,transparent 0 26px,rgba(255,255,255,0.05) 26px 27px);"></span>
        <span class="pointer-events-none absolute inset-0" aria-hidden="true"
          style="background:radial-gradient(60% 70% at 50% 42%, rgba(74,146,209,0.22), transparent 70%);"></span>
        <span class="absolute inset-0 flex flex-col items-center justify-center gap-2 text-center">
          <span class="grid h-11 w-11 place-items-center rounded-full bg-blue text-white shadow-lg transition-transform duration-300 group-hover:-translate-y-0.5">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true"><path d="M12 21s-7-5.2-7-10a7 7 0 0 1 14 0c0 4.8-7 10-7 10Z"/><circle cx="12" cy="11" r="2.5"/></svg>
          </span>
          <span class="inline-flex items-center gap-1.5 text-[14px] font-semibold text-white">
            {locale === 'he' ? 'צפייה במפה' : 'View on map'}
            <span class="text-blue-bright">{locale === 'he' ? '←' : '→'}</span>
          </span>
        </span>
      </a>
    </aside>
  </div>
</section>

<script define:vars={{ a }}>
  const form = document.getElementById('appt-form');
  if (form) {
    const status = form.querySelector('[data-status]');
    const btn = form.querySelector('button[type=submit]');
    const label = form.querySelector('[data-label]');
    const labelText = label?.textContent ?? '';
    const show = (msg, ok) => {
      status.textContent = msg;
      status.classList.remove('hidden');
      status.style.background = ok ? 'rgba(45,114,176,0.20)' : 'rgba(194,90,70,0.18)';
      status.style.color = ok ? '#cfe9e2' : '#f3c9c1';
    };
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const data = Object.fromEntries(new FormData(form));
      if (data.company) return; // honeypot
      if (!data.name || !data.phone || !data.email) { show(a.error, false); return; }
      btn.disabled = true;
      if (label) label.textContent = a.sending;
      try {
        const res = await fetch('/api/contact', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });
        const json = await res.json().catch(() => ({}));
        if (res.ok && json.ok) {
          form.reset();
          show(a.success, true);
        } else {
          show(json.error || a.error, false);
        }
      } catch {
        show(a.error, false);
      } finally {
        btn.disabled = false;
        if (label) label.textContent = labelText;
      }
    });
  }
</script>
