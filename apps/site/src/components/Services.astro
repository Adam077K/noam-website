---
import type { Locale } from '@/lib/i18n';
import { getContent } from '@/lib/content';
import Eyebrow from './Eyebrow.astro';
import Icon from './Icon.astro';
interface Props { locale: Locale }
const { locale } = Astro.props;
const t = getContent(locale);
---
<section id="services" class="scroll-mt-24 border-t border-sand bg-bone">
  <div class="mx-auto max-w-[1240px] px-6 py-20 lg:px-10 lg:py-28">
    <div class="reveal mb-12 max-w-[42rem]">
      <Eyebrow text={t.services.eyebrow} class="mb-5" />
      <h2 class="mb-4 font-serif text-[clamp(1.9rem,3.6vw,2.85rem)] font-bold leading-[1.12] text-ink">{t.services.heading}</h2>
      <p class="text-[17px] leading-relaxed text-clay">{t.services.intro}</p>
    </div>

    <div class="grid grid-cols-1 gap-px overflow-hidden rounded-[4px] border border-sand bg-sand sm:grid-cols-2 lg:grid-cols-3">
      {t.services.items.map((s, i) => (
        <article class="reveal group flex flex-col bg-bone-2 p-7 transition-colors duration-300 hover:bg-bone" style={`transition-delay:${(i % 3) * 0.06}s`}>
          <span class="mb-5 grid h-12 w-12 place-items-center rounded-full bg-green/10 text-green transition-colors group-hover:bg-green group-hover:text-white">
            <Icon name={s.icon} size={22} />
          </span>
          <h3 class="mb-2.5 font-serif text-[20px] font-bold leading-snug text-ink">{s.title}</h3>
          <p class="text-[15px] leading-relaxed text-clay">{s.body}</p>
        </article>
      ))}
    </div>
  </div>
</section>
