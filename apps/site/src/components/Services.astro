---
import type { Locale } from '@/lib/i18n';
import { getContent } from '@/lib/content';
import Eyebrow from './Eyebrow.astro';
import Icon from './Icon.astro';
interface Props { locale: Locale }
const { locale } = Astro.props;
const t = getContent(locale);
---
<section id="services" class="scroll-mt-24 bg-sky">
  <div class="mx-auto max-w-[1240px] px-6 py-20 lg:px-10 lg:py-28">
    <!-- asymmetric header: heading on the start, intro on the end -->
    <div class="reveal mb-14 grid grid-cols-1 gap-6 lg:grid-cols-[1fr_0.9fr] lg:items-end lg:gap-16">
      <div>
        <Eyebrow text={t.services.eyebrow} class="mb-5" />
        <h2 class="reveal-title font-serif text-[clamp(1.9rem,3.6vw,2.95rem)] font-bold leading-[1.1] text-ink">{t.services.heading}</h2>
      </div>
      <p class="text-[17px] leading-relaxed text-slate lg:pb-2">{t.services.intro}</p>
    </div>

    <!-- ruled index: two columns of rows (denser + distinct from a card grid) -->
    <div class="grid grid-cols-1 gap-x-16 md:grid-cols-2">
      {t.services.items.map((s, i) => (
        <article class="reveal group flex items-start gap-6 border-t border-blue/15 py-8" style={`transition-delay:${(i % 2) * 0.06}s`}>
          <span class="mt-1 shrink-0 text-blue transition-transform duration-300 group-hover:-translate-y-0.5">
            <Icon name={s.icon} size={30} />
          </span>
          <div>
            <h3 class="mb-1.5 font-serif text-[20px] font-bold leading-snug text-ink">{s.title}</h3>
            <p class="text-[15.5px] leading-relaxed text-slate">{s.body}</p>
          </div>
          <span class="ms-auto hidden self-center text-blue/30 transition-all duration-300 group-hover:text-blue lg:block" aria-hidden="true">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
              {locale === 'he' ? <path d="M15 6l-6 6 6 6" /> : <path d="M9 6l6 6-6 6" />}
            </svg>
          </span>
        </article>
      ))}
    </div>
  </div>
</section>
