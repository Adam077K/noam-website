---
import type { Locale } from '@/lib/i18n';
import { getContent } from '@/lib/content';
import Eyebrow from './Eyebrow.astro';
import Icon from './Icon.astro';
interface Props { locale: Locale }
const { locale } = Astro.props;
const t = getContent(locale);
---
<section id="services" class="scroll-mt-24 bg-sky">
  <div class="mx-auto max-w-[1240px] px-6 py-20 lg:px-10 lg:py-28">
    <div class="reveal mb-12 max-w-[42rem]">
      <Eyebrow text={t.services.eyebrow} class="mb-5" />
      <h2 class="mb-4 font-serif text-[clamp(1.9rem,3.6vw,2.85rem)] font-bold leading-[1.12] text-ink">{t.services.heading}</h2>
      <p class="text-[17px] leading-relaxed text-slate">{t.services.intro}</p>
    </div>

    <div class="grid grid-cols-1 gap-px overflow-hidden rounded-[22px] border border-line bg-line sm:grid-cols-2 lg:grid-cols-3">
      {t.services.items.map((s, i) => (
        <article class="reveal group flex flex-col bg-paper-2 p-7 transition-colors duration-300 hover:bg-paper" style={`transition-delay:${(i % 3) * 0.06}s`}>
          <div class="mb-5 text-blue">
            <Icon name={s.icon} size={30} />
            <div class="mt-3.5 h-px w-9 bg-blue/30 transition-all duration-300 group-hover:w-14 group-hover:bg-blue/60"></div>
          </div>
          <h3 class="mb-2.5 font-serif text-[20px] font-bold leading-snug text-ink">{s.title}</h3>
          <p class="text-[15px] leading-relaxed text-slate">{s.body}</p>
        </article>
      ))}
    </div>
  </div>
</section>
