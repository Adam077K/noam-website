---
import type { Locale } from '@/lib/i18n';
import { getContent } from '@/lib/content';
import Eyebrow from './Eyebrow.astro';
import CtaButton from './CtaButton.astro';
interface Props { locale: Locale }
const { locale } = Astro.props;
const t = getContent(locale);
const parseStat = (n: string) => {
  const m = n.match(/^(\D*)(\d+(?:\.\d+)?)(\D*)$/);
  if (!m) return { countable: false } as const;
  const num = parseFloat(m[2]);
  return { countable: num <= 100, num, prefix: m[1], suffix: m[3], decimals: m[2].includes('.') ? 1 : 0 };
};
---
<section id="about" class="scroll-mt-24 bg-paper">
  <div class="mx-auto grid max-w-[1240px] grid-cols-1 items-center gap-12 px-6 py-20 lg:grid-cols-[0.74fr_1.26fr] lg:gap-16 lg:px-10 lg:py-28">
    <!-- portrait: natural, contained, professional -->
    <div class="reveal relative mx-auto w-full max-w-[380px] lg:mx-0">
      <div class="overflow-hidden rounded-[22px] bg-sky shadow-[var(--shadow-card)] ring-1 ring-line" style="aspect-ratio:4/5">
        <img src="/img/noam-about.avif" alt={t.about.photoAlt} width="760" height="950" loading="lazy" decoding="async" class="h-full w-full object-cover object-top" />
      </div>
      <span class="pointer-events-none absolute -bottom-3 -end-3 -z-10 h-24 w-24 rounded-[18px] bg-sky-2" aria-hidden="true"></span>
    </div>

    <!-- text -->
    <div class="reveal" style="transition-delay:.08s">
      <Eyebrow text={t.about.eyebrow} class="mb-5" />
      <h2 class="reveal-title mb-6 max-w-[15em] font-serif text-[clamp(1.9rem,3.6vw,2.85rem)] font-bold leading-[1.14] text-ink">{t.about.heading}</h2>
      {t.about.body.map((p) => (
        <p class="mb-4 max-w-[42rem] text-[17px] leading-[1.78] text-[#46586a]">{p}</p>
      ))}

      <!-- stat box: soft navy->blue gradient, high-contrast labels -->
      <div class="mt-9 grid grid-cols-2 overflow-hidden rounded-[18px] shadow-[var(--shadow-card)] sm:grid-cols-4" style="background:linear-gradient(120deg,#0e2236,#19456b);">
        {t.about.stats.map((s, i) => {
          const p = parseStat(s.n);
          return (
            <div class={`p-5 ${i % 2 === 1 ? 'border-s border-white/12' : ''} ${i >= 2 ? 'border-t border-white/12 sm:border-t-0' : ''} ${i % 4 !== 0 ? 'sm:border-s sm:border-white/12' : ''}`}>
              <div class="font-serif text-[27px] font-bold leading-none text-white" dir="ltr" style="text-align:start">
                {p.countable
                  ? <span data-count-to={p.num} data-count-prefix={p.prefix} data-count-suffix={p.suffix} data-count-decimals={p.decimals}>{p.prefix}0{p.suffix}</span>
                  : s.n}
              </div>
              <div class="mt-2 text-[12.5px] font-medium leading-snug text-[#d3e2f0]">{s.label}</div>
            </div>
          );
        })}
      </div>

      <div class="mt-9"><CtaButton href="#contact" label={t.about.cta} locale={locale} variant="solid" /></div>
    </div>
  </div>
</section>
