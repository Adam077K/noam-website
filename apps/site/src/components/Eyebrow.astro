---
interface Props { text: string; tone?: 'blue' | 'light'; class?: string }
const { text, tone = 'blue', class: cls = '' } = Astro.props;
const color = tone === 'blue' ? 'text-blue' : 'text-blue-bright';
const bar = tone === 'blue' ? 'bg-blue' : 'bg-blue-bright';
---
<span class={`inline-flex items-center gap-2.5 ${cls}`}>
  <span class={`h-3 w-[3px] rounded-full ${bar}`} aria-hidden="true"></span>
  <span class={`text-[12.5px] font-semibold uppercase tracking-[0.18em] ${color}`}>{text}</span>
</span>
