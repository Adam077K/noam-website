---
import type { Locale } from '@/lib/i18n';
import { getContent } from '@/lib/content';
import Eyebrow from './Eyebrow.astro';
import Icon from './Icon.astro';
import VideoCard from './VideoCard.astro';
interface Props { locale: Locale }
const { locale } = Astro.props;
const t = getContent(locale);
---
<section class="bg-paper">
  <div class="mx-auto grid max-w-[1240px] grid-cols-1 items-center gap-12 px-6 py-20 lg:grid-cols-[1fr_0.92fr] lg:gap-16 lg:px-10 lg:py-28">
    <!-- benefits -->
    <div class="reveal">
      <Eyebrow text={t.consult.eyebrow} class="mb-5" />
      <h2 class="mb-9 max-w-[14em] font-serif text-[clamp(1.9rem,3.6vw,2.85rem)] font-bold leading-[1.12] text-ink">{t.consult.heading}</h2>
      <ul class="space-y-7">
        {t.consult.benefits.map((b) => (
          <li class="flex gap-5">
            <span class="mt-1 shrink-0 text-blue">
              <Icon name={b.icon} size={28} />
            </span>
            <div>
              <h3 class="mb-1.5 font-serif text-[20px] font-bold text-ink">{b.title}</h3>
              <p class="max-w-[34rem] text-[15.5px] leading-relaxed text-slate">{b.body}</p>
            </div>
          </li>
        ))}
      </ul>
    </div>

    <!-- featured video -->
    <div class="reveal" style="transition-delay:.1s">
      <div class="rounded-[26px] bg-sky p-2.5 shadow-[var(--shadow-float)]">
        <VideoCard id={t.consult.featured.id} title={t.consult.featured.title} kicker={t.consult.featured.kicker} watch={t.consult.watch} variant="feature" />
      </div>
    </div>
  </div>
</section>
