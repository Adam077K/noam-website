---
import type { Locale } from '@/lib/i18n';
import { getContent } from '@/lib/content';
import Icon from './Icon.astro';
interface Props { locale: Locale }
const { locale } = Astro.props;
const t = getContent(locale);
---
<header id="top" class="absolute inset-x-0 top-0 z-40" data-nav>
  <!-- utility bar -->
  <div class="hidden border-b border-white/8 bg-ink/95 text-bone-muted md:block" data-util>
    <div class="mx-auto flex max-w-[1240px] items-center justify-between px-6 py-2 text-[13px] lg:px-10">
      <div class="flex items-center gap-6">
        <a href={t.utility.phoneHref} class="inline-flex items-center gap-2 transition-colors hover:text-white">
          <Icon name="play" size={0} class="hidden" />
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" aria-hidden="true"><path d="M4 5c0 8.3 6.7 15 15 15l2.5-2.5-4-3-2 1.5a11 11 0 0 1-5.5-5.5L13 8.5l-3-4Z"/></svg>
          <span dir="ltr">{t.utility.phone}</span>
        </a>
        <a href={t.utility.emailHref} class="inline-flex items-center gap-2 transition-colors hover:text-white">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" aria-hidden="true"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3.5 7 8.5 6 8.5-6"/></svg>
          {t.utility.email}
        </a>
      </div>
      <a href={t.langSwitch.otherHref} class="inline-flex items-center gap-1.5 transition-colors hover:text-white" aria-label={`Switch language to ${t.langSwitch.other}`}>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M3 12h18M12 3c2.5 2.5 3.8 5.6 3.8 9S14.5 18.5 12 21c-2.5-2.5-3.8-5.6-3.8-9S9.5 5.5 12 3Z"/></svg>
        <span class="font-semibold">{t.langSwitch.other}</span>
      </a>
    </div>
  </div>

  <!-- main nav -->
  <nav class="bg-transparent transition-colors duration-300" data-bar>
    <div class="mx-auto flex max-w-[1240px] items-center gap-8 px-6 py-4 lg:px-10">
      <a href="#top" class="shrink-0 leading-none">
        <span class="block font-serif text-[22px] font-bold text-white">{t.nav.brand}</span>
        <span class="mt-0.5 block text-[10.5px] font-medium tracking-[0.18em] text-green-2 uppercase">{t.nav.brandSub}</span>
      </a>

      <!-- desktop menu -->
      <div class="ms-auto hidden items-center gap-8 lg:flex">
        {t.nav.items.map((it) => (
          <a href={it.href} class="text-[15.5px] font-medium text-[#e6e9e6]/85 transition-colors hover:text-white">{it.label}</a>
        ))}
        <a href="#contact" class="rounded-[3px] bg-green px-5 py-2.5 text-[15px] font-semibold text-white transition-colors hover:bg-green-2">{t.nav.cta}</a>
      </div>

      <!-- mobile controls -->
      <div class="ms-auto flex items-center gap-3 lg:hidden">
        <a href="#contact" class="rounded-[3px] bg-green px-4 py-2 text-sm font-semibold text-white">{t.nav.cta}</a>
        <button type="button" data-menu-toggle aria-expanded="false" aria-controls="mobile-menu" aria-label="Menu" class="grid h-10 w-10 place-items-center rounded-[3px] border border-white/15 text-white">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" data-icon-open><path d="M4 7h16M4 12h16M4 17h16"/></svg>
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="hidden" data-icon-close><path d="m6 6 12 12M18 6 6 18"/></svg>
        </button>
      </div>
    </div>

    <!-- mobile menu panel -->
    <div id="mobile-menu" data-menu-panel class="hidden border-t border-white/8 bg-ink lg:hidden">
      <div class="mx-auto max-w-[1240px] px-6 py-3">
        {t.nav.items.map((it) => (
          <a href={it.href} data-menu-link class="block border-b border-white/6 py-3.5 text-[17px] font-medium text-[#e6e9e6]">{it.label}</a>
        ))}
        <div class="flex items-center justify-between py-4">
          <a href={t.utility.phoneHref} dir="ltr" class="text-[15px] text-bone-muted">{t.utility.phone}</a>
          <a href={t.langSwitch.otherHref} class="inline-flex items-center gap-1.5 text-[15px] font-semibold text-green-2">{t.langSwitch.other}</a>
        </div>
      </div>
    </div>
  </nav>
</header>

<script>
  const header = document.querySelector('[data-nav]');
  const bar = header?.querySelector('[data-bar]');
  const toggle = header?.querySelector('[data-menu-toggle]');
  const panel = header?.querySelector('[data-menu-panel]');
  const iconOpen = header?.querySelector('[data-icon-open]');
  const iconClose = header?.querySelector('[data-icon-close]');

  const setOpen = (open: boolean) => {
    panel?.classList.toggle('hidden', !open);
    iconOpen?.classList.toggle('hidden', open);
    iconClose?.classList.toggle('hidden', !open);
    toggle?.setAttribute('aria-expanded', String(open));
  };
  toggle?.addEventListener('click', () => setOpen(panel?.classList.contains('hidden') ?? true));
  header?.querySelectorAll('[data-menu-link]').forEach((l) => l.addEventListener('click', () => setOpen(false)));

  // sticky: fix to top + ink background after scrolling past hero top
  const onScroll = () => {
    const scrolled = window.scrollY > 24;
    header?.classList.toggle('fixed', scrolled);
    header?.classList.toggle('absolute', !scrolled);
    header?.classList.toggle('shadow-[0_10px_30px_-18px_rgba(0,0,0,0.6)]', scrolled);
    bar?.classList.toggle('bg-ink/95', scrolled);
    bar?.classList.toggle('backdrop-blur', scrolled);
  };
  onScroll();
  window.addEventListener('scroll', onScroll, { passive: true });
</script>
