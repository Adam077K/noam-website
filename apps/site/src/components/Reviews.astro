---
import type { Locale } from '@/lib/i18n';
import { getContent } from '@/lib/content';
import Eyebrow from './Eyebrow.astro';
interface Props { locale: Locale }
const { locale } = Astro.props;
const t = getContent(locale);
const r = t.reviews;
const isHe = locale === 'he';
const arrow = isHe ? '←' : '→';
const Stars = (n: number) => Array.from({ length: 5 }, (_, i) => i < n);
const STAR = 'M12 3.5 14.6 9l5.9.5-4.5 3.9 1.4 5.8L12 16.9 6.6 19.2 8 13.4 3.5 9.5 9.4 9Z';
const ratingPct = Math.max(0, Math.min(100, (parseFloat(r.rating) / 5) * 100));

// Source-attributed structured data (rating cited to MedReviews, not self-issued)
const jsonld = {
  '@context': 'https://schema.org',
  '@type': 'Physician',
  name: isHe ? 'ד״ר נעם כתרי' : 'Dr. Noam Kitrey',
  medicalSpecialty: 'Urologic',
  telephone: '+972-54-718-1718',
  address: {
    '@type': 'PostalAddress',
    streetAddress: isHe ? 'דרך מנחם בגין 156' : '156 Menachem Begin Rd',
    addressLocality: isHe ? 'תל אביב' : 'Tel Aviv',
    addressCountry: 'IL',
  },
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: r.rating,
    reviewCount: String(r.reviewCount),
    bestRating: '5',
    author: { '@type': 'Organization', name: 'MedReviews', url: r.sourceHref },
  },
};
---
<section id="reviews" class="scroll-mt-24 border-t border-line bg-paper">
  <div class="mx-auto max-w-[1240px] px-6 py-20 lg:px-10 lg:py-28">
    <div class="reveal mb-12 flex flex-col gap-7 sm:flex-row sm:items-end sm:justify-between">
      <div class="max-w-[36rem]">
        <Eyebrow text={r.eyebrow} class="mb-5" />
        <h2 class="font-serif text-[clamp(1.9rem,3.6vw,2.85rem)] font-bold leading-[1.12] text-ink">{r.heading}</h2>
      </div>

      <!-- verified aggregate badge → links to the live MedReviews profile -->
      <div class="flex flex-col items-start gap-2 sm:items-end">
        <a
          href={r.sourceHref} target="_blank" rel="noopener nofollow"
          class="group inline-flex items-center gap-4 rounded-2xl border border-line bg-paper-2 px-5 py-4 shadow-[var(--shadow-card)] transition-all duration-300 hover:-translate-y-0.5 hover:shadow-[var(--shadow-card-hover)]"
          aria-label={`${r.verified} — ${r.rating}`}
        >
          <span class="font-serif text-[40px] font-bold leading-none text-ink">{r.rating}</span>
          <span class="block">
            <span class="relative inline-flex" dir="ltr" aria-hidden="true">
              <span class="flex gap-0.5 text-brass/25">
                {Stars(5).map(() => (<svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d={STAR}/></svg>))}
              </span>
              <span class="absolute inset-y-0 left-0 flex overflow-hidden text-brass" style={`width:${ratingPct}%`}>
                <span class="flex gap-0.5">
                  {Stars(5).map(() => (<svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d={STAR}/></svg>))}
                </span>
              </span>
            </span>
            <span class="mt-1.5 flex items-center gap-1.5 text-[13px] font-medium text-slate">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="text-blue" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="m8.5 12 2.5 2.5 4.5-5"/></svg>
              {r.verified} · {r.count}
            </span>
          </span>
          <span class="text-blue transition-transform duration-300 group-hover:-translate-x-1 rtl:group-hover:translate-x-0 rtl:group-hover:-translate-x-1" aria-hidden="true">{arrow}</span>
        </a>
        <span class="text-[12px] text-slate/80">{r.asOf}</span>
      </div>
    </div>

    <div class="grid grid-cols-1 gap-6 lg:grid-cols-[1.45fr_1fr] lg:gap-10">
      <!-- oversized featured testimonial -->
      <figure class="reveal relative flex flex-col justify-center rounded-[26px] bg-sky p-9 lg:p-14">
        <span class="pointer-events-none absolute top-3 select-none font-serif text-[120px] leading-none text-blue/15 ltr:left-7 rtl:right-7" aria-hidden="true">&ldquo;</span>
        <div class="mb-5 flex gap-0.5 text-brass" aria-label={`${r.items[0].stars} / 5`}>
          {Stars(r.items[0].stars).map(() => (<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d={STAR}/></svg>))}
        </div>
        <blockquote class="relative font-serif text-[clamp(1.45rem,2.4vw,2rem)] font-medium leading-[1.4] text-ink">{r.items[0].quote}</blockquote>
        <figcaption class="mt-7 flex flex-wrap items-center gap-x-3 gap-y-2 text-[15px]">
          <span class="h-px w-8 bg-blue/40"></span>
          <span class="font-semibold text-ink">{r.items[0].name}</span>
          <span class="text-slate">· {r.items[0].meta}</span>
          <a href={r.sourceHref} target="_blank" rel="noopener nofollow" class="ms-auto inline-flex items-center gap-1 text-[13px] font-medium text-blue hover:text-blue-deep">{r.onSource} <span aria-hidden="true">{arrow}</span></a>
        </figcaption>
      </figure>

      <!-- supporting testimonials -->
      <div class="flex flex-col">
        {r.items.slice(1).map((rv, i) => (
          <figure class={`reveal flex flex-col py-7 ${i > 0 ? 'border-t border-line' : ''}`} style={`transition-delay:${i * 0.08}s`}>
            <div class="mb-3 flex gap-0.5 text-brass" aria-label={`${rv.stars} / 5`}>
              {Stars(rv.stars).map(() => (<svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d={STAR}/></svg>))}
            </div>
            <blockquote class="mb-4 text-[16px] leading-[1.7] text-[#27384a]">{rv.quote}</blockquote>
            <figcaption class="flex flex-wrap items-center gap-x-2 gap-y-1 text-[14px]">
              <span class="font-semibold text-ink">{rv.name}</span>
              <span class="text-slate"> · {rv.meta}</span>
              <a href={r.sourceHref} target="_blank" rel="noopener nofollow" class="ms-auto inline-flex items-center gap-1 text-[12.5px] font-medium text-blue hover:text-blue-deep">{r.onSource} <span aria-hidden="true">{arrow}</span></a>
            </figcaption>
          </figure>
        ))}
      </div>
    </div>

    <!-- see-all CTA -->
    <div class="reveal mt-9 flex flex-wrap items-center gap-x-4 gap-y-2">
      <a href={r.sourceHref} target="_blank" rel="noopener nofollow" class="group inline-flex items-center gap-2 rounded-full border border-line bg-paper-2 px-6 py-3 text-[15px] font-semibold text-ink transition-colors hover:border-blue/40 hover:text-blue">
        {r.seeAll}
        <span class="text-blue transition-transform duration-300 group-hover:-translate-x-1 rtl:group-hover:translate-x-0 rtl:group-hover:-translate-x-1" aria-hidden="true">{arrow}</span>
      </a>
    </div>
  </div>

  <script type="application/ld+json" set:html={JSON.stringify(jsonld)} />
</section>
