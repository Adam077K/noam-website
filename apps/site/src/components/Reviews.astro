---
import type { Locale } from '@/lib/i18n';
import { getContent } from '@/lib/content';
import Eyebrow from './Eyebrow.astro';
interface Props { locale: Locale }
const { locale } = Astro.props;
const t = getContent(locale);
const Stars = (n: number) => Array.from({ length: 5 }, (_, i) => i < n);
const STAR = 'M12 3.5 14.6 9l5.9.5-4.5 3.9 1.4 5.8L12 16.9 6.6 19.2 8 13.4 3.5 9.5 9.4 9Z';
const ratingPct = Math.max(0, Math.min(100, (parseFloat(t.reviews.rating) / 5) * 100));
---
<section id="reviews" class="scroll-mt-24 border-t border-line bg-paper">
  <div class="mx-auto max-w-[1240px] px-6 py-20 lg:px-10 lg:py-28">
    <div class="reveal mb-12 flex flex-col gap-6 sm:flex-row sm:items-end sm:justify-between">
      <div class="max-w-[36rem]">
        <Eyebrow text={t.reviews.eyebrow} class="mb-5" />
        <h2 class="font-serif text-[clamp(1.9rem,3.6vw,2.85rem)] font-bold leading-[1.12] text-ink">{t.reviews.heading}</h2>
      </div>
      <div class="flex items-center gap-4">
        <div class="font-serif text-[44px] font-bold leading-none text-ink">{t.reviews.rating}</div>
        <div>
          <div class="relative inline-flex" dir="ltr" aria-hidden="true">
            <div class="flex gap-0.5 text-brass/25">
              {Stars(5).map(() => (
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d={STAR}/></svg>
              ))}
            </div>
            <div class="absolute inset-y-0 left-0 overflow-hidden text-brass" style={`width:${ratingPct}%`}>
              <div class="flex gap-0.5">
                {Stars(5).map(() => (
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d={STAR}/></svg>
                ))}
              </div>
            </div>
          </div>
          <div class="mt-1 text-[13.5px] text-slate">{t.reviews.count}</div>
        </div>
      </div>
    </div>

    <div class="grid grid-cols-1 gap-6 lg:grid-cols-[1.45fr_1fr] lg:gap-10">
      <!-- oversized featured testimonial -->
      <figure class="reveal relative flex flex-col justify-center rounded-[26px] bg-sky p-9 lg:p-14">
        <span class="pointer-events-none absolute top-3 select-none font-serif text-[120px] leading-none text-blue/15 ltr:left-7 rtl:right-7" aria-hidden="true">&ldquo;</span>
        <div class="mb-5 flex gap-0.5 text-brass" aria-label={`${t.reviews.items[0].stars} / 5`}>
          {Stars(t.reviews.items[0].stars).map(() => (
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d={STAR}/></svg>
          ))}
        </div>
        <blockquote class="relative font-serif text-[clamp(1.45rem,2.4vw,2rem)] font-medium leading-[1.4] text-ink">{t.reviews.items[0].quote}</blockquote>
        <figcaption class="mt-7 flex items-center gap-3 text-[15px]">
          <span class="h-px w-8 bg-blue/40"></span>
          <span class="font-semibold text-ink">{t.reviews.items[0].name}</span>
          <span class="text-slate">· {t.reviews.items[0].meta}</span>
        </figcaption>
      </figure>

      <!-- supporting testimonials -->
      <div class="flex flex-col">
        {t.reviews.items.slice(1).map((r, i) => (
          <figure class={`reveal flex flex-col py-7 ${i > 0 ? 'border-t border-line' : ''}`} style={`transition-delay:${i * 0.08}s`}>
            <div class="mb-3 flex gap-0.5 text-brass" aria-label={`${r.stars} / 5`}>
              {Stars(r.stars).map(() => (
                <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d={STAR}/></svg>
              ))}
            </div>
            <blockquote class="mb-4 text-[16px] leading-[1.7] text-[#27384a]">{r.quote}</blockquote>
            <figcaption class="text-[14px]">
              <span class="font-semibold text-ink">{r.name}</span>
              <span class="text-slate"> · {r.meta}</span>
            </figcaption>
          </figure>
        ))}
      </div>
    </div>

    <p class="reveal mt-7 text-[13.5px] text-slate">
      <a href={t.reviews.sourceHref} target="_blank" rel="noopener noreferrer" class="underline decoration-line underline-offset-4 transition-colors hover:text-blue">{t.reviews.sourceLabel}</a>
    </p>
  </div>
</section>
