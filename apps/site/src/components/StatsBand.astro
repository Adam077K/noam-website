---
import type { Locale } from '@/lib/i18n';
import { getContent } from '@/lib/content';
interface Props { locale: Locale }
const { locale } = Astro.props;
const t = getContent(locale);
const parseStat = (n: string) => {
  const m = n.match(/^(\D*)(\d+(?:\.\d+)?)(\D*)$/);
  if (!m) return { countable: false } as const;
  const num = parseFloat(m[2]);
  return { countable: num <= 100, num, prefix: m[1], suffix: m[3], decimals: m[2].includes('.') ? 1 : 0 };
};
---
<section class="relative overflow-hidden" style="background:linear-gradient(110deg, #0e2236 0%, #18476e 55%, #245f93 100%);">
  <div class="pointer-events-none absolute inset-0" aria-hidden="true"
    style="background:radial-gradient(80% 120% at 85% 0%, rgba(120,180,230,0.22), transparent 55%);"></div>
  <div class="relative mx-auto grid max-w-[1240px] grid-cols-1 divide-y divide-white/15 px-6 py-16 sm:grid-cols-3 sm:divide-x sm:divide-y-0 lg:px-10 rtl:sm:divide-x-reverse">
    {t.statsBand.map((s, i) => {
      const p = parseStat(s.n);
      return (
        <div class="reveal px-4 py-6 text-center sm:py-2" style={`transition-delay:${i * 0.08}s`}>
          <div class="font-serif text-[clamp(2.6rem,5vw,3.4rem)] font-bold leading-none text-white" dir="ltr">
            {p.countable
              ? <span data-count-to={p.num} data-count-prefix={p.prefix} data-count-suffix={p.suffix} data-count-decimals={p.decimals}>{p.prefix}{p.num.toFixed(p.decimals)}{p.suffix}</span>
              : s.n}
          </div>
          <div class="mx-auto mt-3 max-w-[18rem] text-[14px] leading-snug text-white">{s.label}</div>
        </div>
      );
    })}
  </div>
</section>
