# ─────────────────────────────────────────────────────────────────────────
# Contact form (apps/web/src/lib/contact + src/app/actions/contact.ts)
# All keys below are OPTIONAL in local dev — the backend degrades gracefully:
#   • No RESEND_API_KEY  → emails are skipped (logged), submission still "ok".
#   • No UPSTASH_* vars  → rate limit falls back to in-memory (resets on cold start).
# Set them all in production.
# ─────────────────────────────────────────────────────────────────────────

# Resend API key for transactional email (https://resend.com/api-keys).
RESEND_API_KEY=

# Where clinic notification emails are delivered. Defaults to Dr.Kitrey@gmail.com.
CONTACT_TO_EMAIL=Dr.Kitrey@gmail.com

# Upstash Redis REST credentials for IP rate limiting (3 submissions / 10 min).
# https://console.upstash.com → your DB → REST API.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
